<% for (const item of items) { 
  let maturityIcon = '🌱';
  if (item.maturity === 'evergreen') maturityIcon = '🌳';
  else if (item.maturity === 'sprout') maturityIcon = '🌿';
  let dateLabel = '';
  if (item.date) {
    const d = item.date instanceof Date ? item.date : new Date(item.date);
    if (!isNaN(d)) {
      dateLabel = d.toLocaleDateString('en-US', { 
        month: 'short', 
        year: 'numeric' 
      }).toLowerCase();
    }
  }
%>
<article class="note-item" data-maturity="<%= maturityIcon %>"><div class="note-content"><a class="note-title" href="<%- item.path %>"><%- item.title %></a><% if (dateLabel) { %><div class="note-meta"><%= dateLabel %></div><% } %></div></article>
<% } %>